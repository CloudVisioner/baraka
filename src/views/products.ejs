
<%- include('includes/header') %>

<link rel="stylesheet" type="text/css" href="/css/products.css" />

<body>
  <div class="products-container">
    <div class="navigation-menu">
      <ul class="nav justify-content-center">
        <li class="nav-item">
          <a class="nav-link" href="/admin/">Home</a>
        </li>
        <li class="nav-item">
          <a class="nav-link active" href="/admin/product/all">Menu</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/admin/event/all">Events</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/admin/user/all">Users</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/admin/order/all">Orders</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/admin/logout" onclick="return confirm('Do you want to logout?')">Logout</a>
        </li>
      </ul>
    </div>

    <div class="restaurant-menu-frame">
      <div class="board">
        <div class="dishes-table">
          <span class="new-dish-txt" style="margin-bottom: 30px">
            BOOK MANAGEMENT
          </span>
          <table class="table table-bordered table-hover">
            <thead class="thead-light">
              <tr class="thead-light">
                <th scope="col">T/r</th>
                <th scope="col">Book Name</th>
                <th scope="col">Author Name</th>
                <th scope="col">Product Type</th>
                <th scope="col">Product Format</th>
                <th scope="col">Product Price</th>
                <th scope="col">Product Left Count</th>
                <th scope="col">Status</th>
              </tr>
            </thead>
            <!--  LOOP PRODUCTS: START  -->
            <% products.map(function(value, key) { %>
            <tbody style="background: white">
              <td><%= key + 1 %></td>
              <td><%= value.productName %></td>
              <td><%= value.productAuthor || 'N/A' %></td>
              <td><%= value.productType || value.productCollection %></td>
              <td><%= value.productFormat || value.ProductType %></td>
              <td><%= value.productPrice %></td>
              <td><%= value.productLeftCount %></td>
              <td>
                <select class="spec-select new-product-status" id="<%=value._id || value.id %>">
                  <option value="PAUSE" <%= value.productStatus === 'PAUSE' ? 'selected': '' %>>PAUSE</option>
                  <option value="PROCESS" <%= value.productStatus === 'PROCESS' ? 'selected': '' %>>PROCESS</option>
                  <option value="DELETE" <%= value.productStatus === 'DELETE' ? 'selected': '' %>>DELETE</option>
                </select>
              </td>
            </tbody>
            <% }) %>
          </table>
          <div
            class="long-input"
            style="align-items: flex-end; margin-bottom: 25px"
          >
            <button class="btn btn-primary" id="process-btn">
              New Product
            </button>
          </div>
        </div>

        <form
        onsubmit="return validateForm()"
          action="/admin/product/create"
          method="POST"
          class="dish-container"
          enctype="multipart/form-data"
        >
          <div class="long-input" style="display: flex; align-items: center; margin-bottom: 10px;">
            <h2 style="font-size: 24px; font-weight: 600; color: var(--apple-text); letter-spacing: -0.02em; margin: 0;">Add New Book</h2>
          </div>
          <div class="login-input-frame">
            <input
              name="productStatus"
              value="PAUSE"
              class="product-status"
              hidden
            />
          </div>
          <div class="half-input-frame">
            <div class="half-input">
              <label>Product Name</label>
              <input
                type="text"
                placeholder="Name"
                name="productName"
                class="product-name"
              />
            </div>
            <div class="half-input">
              <label>Author Name</label>
            <input
                type="text"
                placeholder="Author Name"
                name="productAuthor"
                class="product-author"
            />
            </div>
          </div>
          <div class="half-input-frame">
            <div class="half-input">
              <label>Product Price</label>
              <input
                type="number"
                placeholder="Price"
                name="productPrice"
                class="product-price"
                min="0"
                step="0.01"
              />
            </div>
            <div class="half-input">
              <label>Product Left Counts</label>
              <input
                type="number"
                placeholder="Counts"
                name="productLeftCount"
                class="product-left-count"
                min="0"
              />
            </div>
          </div>
          <div class="half-input-frame">
            <div class="half-input">
              <label>Product Type</label>
              <select class="product-type" name="productType">
                <option value="FICTION" selected>Fiction</option>
                <option value="NON_FICTION">Non Fiction</option>
                <option value="ACADEMIC">Academic</option>
                <option value="COMIC">Comic</option>
                <option value="OTHER">Other</option>
              </select>
            </div>

            <div class="half-input" id="product-format">
              <label>Product Format</label>
              <select class="product-format" name="productFormat">
                <option value="PAPERBACK" selected>Paperback</option>
                <option value="HARDCOPY">Hard Copy</option>
              </select>
            </div>

          </div>
          <div class="half-input-frame">
            <div class="half-input">
              <label>Publisher</label>
              <input
                type="text"
                placeholder="Publisher Name"
                name="productPublisher"
                class="product-publisher"
              />
            </div>
            <div class="half-input">
              <label>Publication Date</label>
              <input
                type="text"
                placeholder="e.g., May 6, 2003"
                name="productPublicationDate"
                class="product-publication-date"
              />
            </div>
          </div>
          <div class="half-input-frame">
            <div class="half-input">
              <label>Language</label>
              <select class="product-language" name="productLanguage">
                <option value="ENGLISH" selected>English</option>
                <option value="UZBEK">Uzbek</option>
                <option value="RUSSIAN">Russian</option>
              </select>
            </div>
            <div class="half-input">
              <label>Page Count</label>
              <input
                type="number"
                placeholder="e.g., 272"
                name="productPageCount"
                class="product-page-count"
                min="0"
              />
            </div>
          </div>
          <div class="long-input">
            <label>Product Description</label>
            <textarea name="productDesc" class="product-desc"></textarea>
          </div>

          <div class="img-frame">
            <label>Product Images</label>
            <div class="media-frame">
              <div class="upload-img-box">
                <img src="/img/upload.svg" class="1" id="image-section-1" />
                <input
                  type="file"
                  id="file"
                  name="productImages"
                  class="image-one"
                  required
                  onchange="previewFileHandler(this, 1)"
                />
              </div>
              <div class="upload-img-box">
                <img src="/img/upload.svg" class="2" id="image-section-2" />
                <input
                  type="file"
                  id="file"
                  name="productImages"
                  class="image-two"
                  onchange="previewFileHandler(this, 2)"
                />
              </div>
              <div class="upload-img-box">
                <img src="/img/upload.svg" class="3" id="image-section-3" />
                <input
                  type="file"
                  id="file"
                  name="productImages"
                  class="image-three"
                  onchange="previewFileHandler(this, 3)"
                />
              </div>
              <div class="upload-img-box">
                <img src="/img/upload.svg" class="4" id="image-section-4" />
                <input
                  type="file"
                  id="file"
                  name="productImages"
                  class="image-four"
                  onchange="previewFileHandler(this, 4)"
                />
              </div>
              <div class="upload-img-box">
                <img src="/img/upload.svg" class="5" id="image-section-5" />
                <input
                  type="file"
                  id="file"
                  name="productImages"
                  class="image-five"
                  onchange="previewFileHandler(this, 5)"
                />
              </div>
              <input name="restaurantIid" class="restaurant-id" hidden />
            </div>
          </div>

          <div class="operation-buttons">
            <button class="btn btn-danger" id="cancel-btn">Cancel</button>
            <button type="submit" class="btn btn-primary" id="create-btn">
              Create
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script type="text/javascript" src="/js/products.js"></script>
</body>

<%- include('includes/footer') %>
